      {"term": "Pas de Basque", "definition": "Circular traveling step."}
    ],

    "Intermediate": [
      {"term": "Grand Allegro", "definition": "Large traveling jumps."},
      {"term": "Double Pirouette", "definition": "Two rotations on one leg."},

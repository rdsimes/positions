      {"term": "Tour en l'air", "definition": "Turn in the air."}
    ],

    "Advanced 1": [
      {"term": "Triple Pirouette", "definition": "Three rotations on one leg."},
      {"term": "Brisé", "definition": "Beaten gliding jump."},
      {"term": "Grand Sissonne", "definition": "Large sissonne traveling jump."}

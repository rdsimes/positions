    "Advanced 2": [
      {"term": "Manège", "definition": "Circular traveling sequence."},
      {"term": "Grand Pirouette", "definition": "Large turning movement."},
      {"term": "Multiple Fouettés", "definition": "Series of whipping turns."}
    ]
  }
}